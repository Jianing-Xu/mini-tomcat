<?xml version="1.0" encoding="UTF-8"?>
<web-app>
    <servlet>
        <servlet-name>demoServlet</servlet-name>
        <servlet-class>examples.phase1basic.DemoServlet</servlet-class>
    </servlet>
    <servlet>
        <servlet-name>demoServletV2</servlet-name>
        <servlet-class>examples.phase1basic.DemoServlet</servlet-class>
    </servlet>

    <servlet-mapping>
        <servlet-name>demoServlet</servlet-name>
        <url-pattern>/demo</url-pattern>
    </servlet-mapping>
    <servlet-mapping>
        <servlet-name>demoServletV2</servlet-name>
        <url-pattern>/demo</url-pattern>
    </servlet-mapping>
</web-app>
